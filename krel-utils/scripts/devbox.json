{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.0/.schema/devbox.schema.json",
  "packages": [
    "uv@latest",
    "git@latest",
    "gh@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'release-notes scripts ready. Run any ./<script>.py directly (uv resolves deps on first run). See README.md.'"
    ],
    "scripts": {
      "warmup": [
        "uv run --script find_missing_release_notes.py --self-test",
        "uv run --script sync_map_fields.py --help || true"
      ]
    }
  }
}
